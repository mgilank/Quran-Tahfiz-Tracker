{"surahNumber":114,"ayahs":[{"number":1,"text":"قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ","translation":"Katakanlah, \"Aku berlindung kepada Tuhannya manusia,"},{"number":2,"text":"مَلِكِ ٱلنَّاسِ","translation":"Raja manusia,"},{"number":3,"text":"إِلَٰهِ ٱلنَّاسِ","translation":"sembahan manusia,"},{"number":4,"text":"مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ","translation":"dari kejahatan (bisikan) setan yang bersembunyi,"},{"number":5,"text":"ٱلَّذِي يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ","translation":"yang membisikkan (kejahatan) ke dalam dada manusia,"},{"number":6,"text":"مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ","translation":"dari (golongan) jin dan manusia.\""}]}