{"surahNumber":107,"ayahs":[{"number":1,"text":"أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ","translation":"Tahukah kamu (orang) yang mendustakan agama?"},{"number":2,"text":"فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ","translation":"Maka itulah orang yang menghardik anak yatim,"},{"number":3,"text":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ","translation":"dan tidak mengajak memberi makan orang miskin."},{"number":4,"text":"فَوَيۡلٞ لِّلۡمُصَلِّينَ","translation":"Maka celakalah orang yang salat,"},{"number":5,"text":"ٱلَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ","translation":"(yaitu) orang-orang yang lalai terhadap salatnya,"},{"number":6,"text":"ٱلَّذِينَ هُمۡ يُرَآءُونَ","translation":"yang berbuat riya`,"},{"number":7,"text":"وَيَمۡنَعُونَ ٱلۡمَاعُونَ","translation":"dan enggan (memberikan) bantuan."}]}